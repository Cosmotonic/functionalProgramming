// Declare an F# function countAlbum2 with same type as countAlbum that returns exact same
// results as countAlbum. Only difference is that you must code your own helper function to
// traverse the list of picture and album elements, that is, no use of library aggregation functions like
// List.fold.

let rec countAlbum2 album =
    let rec helper elems (albums, pictures) =
        match elems with
        | [] -> (albums, pictures)

        | h::t ->
            match h with
            | PicElem _ ->
                helper t (albums, pictures + 1)

            | AlbumElem (_, innerAlbum) ->
                let (innerAlbums, innerPictures) = countAlbum2 innerAlbum

                helper t
                    (albums + 1 + innerAlbums,
                     pictures + innerPictures)

    helper album (0,0)



// Question 2.4
//  • Declare an F# function flattenAlbum album of type Elem list-> string list that
//  returns all album and picture element names in a list. You decide, but need to explain, what order
//  the names have in the result list. For instance, flattenAlbum album1 may return
//  val it : string list =
//  ["All"; "Peter.jpg"; "Familiy"; "Mother.jpg";
//  "Farther.jpg"; "Gitte.jpg"; "School"; "Hans.jpg"]


let rec flattenAlbum album = 
    match album with 
    | [] -> []
    | h::t -> match h with 
                | PicElem name -> [name] @ flattenAlbum t
                | AlbumElem (name, innerPictureLits) -> [name] @ flattenAlbum innerPictureLits @ flattenAlbum t

flattenAlbum basketAlbum

