
// Question 1 (20%)
// Consider the F# type TwoLists and function f below.

type TwoLists = {listX: int list;
                 listY: int list}
let rec f {listX = lX; listY = lY} =
    match (lX, lY) with
    ([], [])-> f {listX=[]; listY=[]}           // Result is an infinity recursion. if both are empty then start empty lists. 
    | ([], y::ys)-> f {listX=[y]; listY = ys}   // put first element of Y into X and move it from Y
    | (x::xs, [])-> {listX=x::xs; listY = []}   // if Y is empty just keep X as is and keep Y empty
    | (xs, y::ys)-> f {listX=y::xs; listY = ys} // both lists contain something pu y in front of the X list

