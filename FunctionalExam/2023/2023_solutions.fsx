// Declare an F# function ppAlbum album of type Elem list-> string that returns a string
// representing a pretty printed album. The result string must have the format as shown below.

let newL i = System.Environment.NewLine + "".PadLeft(i,' ')

let rec ppAlbum album = 
    match album with 
    | [] -> "" 
    | h::t -> match h with 
                | PicElem name -> name + newL 0 + ppAlbum t // if its just a picture return it to name run ppAlbum on rest. 
                | AlbumElem (name, innerAlbum) -> name + newL 0 + ppAlbum innerAlbum + ppAlbum t 

ppAlbum basketAlbum

// Question 2.3
// • Declare an F# function countAlbum album of type Elem list-> int * int that returns
// a pair with first element being number of album elements and second element being number
// of picture elements. For instance countAlbum album1 evaluates to the pair (3,5). Also
// countAlbumalbum2evaluatesto(3,6). Notice, theimplementation of countAlbummust
// make use of the list library, e.g., a function like List.fold.

let rec countAlbum album = 
    List.fold (fun (albums, pictures) elem ->
        match elem with 
        | PicElem _ ->(albums, pictures + 1)
        | AlbumElem (_, innerAlbum) ->
            let (innerAlbums, innerPictures) = countAlbum innerAlbum
            (albums + 1 + innerAlbums, pictures + innerPictures)
    ) (0,0) album 
    // læg mærke til vi folder ALT ind i ( )

countAlbum basketAlbum

